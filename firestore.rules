// Firestore Security Rules for LM Dashboard
// Apply these in: Firebase Console → Firestore Database → Rules
// ─────────────────────────────────────────────────────────────────────────────

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Allow read on reports only if the user is signed in with an allowed domain
    match /reports/{docId} {
      allow read: if request.auth != null
                  && (request.auth.token.email.matches('.*@spxexpress\\.com')
                   || request.auth.token.email.matches('.*@shopee\\.com'));

      // No client-side writes — data is seeded via the Admin SDK only
      allow write: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
